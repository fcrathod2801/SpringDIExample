<?xml version = "1.0" encoding = "UTF-8"?>

<beans xmlns = "http://www.springframework.org/schema/beans"
       xmlns:xsi = "http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation = "http://www.springframework.org/schema/beans
   http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">

    <bean id="emp1" class="com.bean.life.Emp1">
        <property name="name" value="Avinash Shankar Rathod"/>
    </bean>

    <!-- Bean ID -->
    <bean id="engine" class="com.anotherexample.autowired.Engine"/>
    <!-- Autowire byName -->
    <bean id="car" class="com.anotherexample.autowired.Car"  autowire="byName"/>

</beans>