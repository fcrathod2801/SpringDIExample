<?xml version = "1.0" encoding = "UTF-8"?>

<beans xmlns = "http://www.springframework.org/schema/beans"
       xmlns:xsi = "http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation = "http://www.springframework.org/schema/beans
   http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">

    <bean id = "helloWorld" class = "com.example.HelloWorld">
        <property name = "message" value = "Hello World!"/>
    </bean>
    <bean id="messageService"
          class="com.beanexample.MessageServiceImpl"/>

    <bean id="s" class="com.beanexample.Student">
        <constructor-arg value="Avinash S Rathod"/>
    </bean>

    <bean id = "employee" class = "com.anotherexample.Employee">
        <property name = "name" value = "Avinash Shankar Rathod"/>
        <property name = "id" value = "101"/>
        <property name = "department" value = "Computer Science!"/>
        <property name = "salary" value = "10000"/>
        <property name = "email" value = "avinash.rathod2001@gmail.com"/>

    </bean>
</beans>